# Health Hub — Environment Variables
# Copy this file to .env.local (dev) or .env.production (Pi)

# Local PostgreSQL for Docker Compose.
# `docker compose --env-file .env.local up -d postgres` reads these values directly.
POSTGRES_DB="health_hub"
POSTGRES_USER="healthhub_user"
POSTGRES_PASSWORD="healthhub_password"
POSTGRES_PORT="5432"

# Prisma / Next.js database connection string.
# Must include ?schema=health_hub to isolate from other apps.
DATABASE_URL="postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@localhost:$POSTGRES_PORT/$POSTGRES_DB?schema=health_hub"

# NextAuth — single-user password auth
AUTH_PASSWORD="your-strong-password"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"  # Change to https://health.hammez.net in production

# Anthropic API — for AI digest generation (Phase 6)
ANTHROPIC_API_KEY="sk-ant-..."

# Garmin Connect — used by scripts/garmin-sync.py (not by the Next.js app)
GARMIN_EMAIL="your-garmin-email@example.com"
GARMIN_PASSWORD="your-garmin-password"

# Cron job authentication — for API routes triggered by cron
CRON_API_KEY=""  # Generate with: openssl rand -base64 32
